# ============================================================
# LLM 模型配置
#
# 本地：可在 agent/config.yaml 写模型；或用下面变量 + 生成配置
# 生产（Render）：必须用环境变量，容器启动时写入 config.yaml
#
# MODEL_TYPE 可选值（仅文档说明；实际以 MODEL_USE / MODEL_NAME 为准）:
#   openai 兼容 → MODEL_USE=langchain_openai:ChatOpenAI
# ============================================================

# --- OpenAI 兼容接口（DeepSeek / 硅基流动 / OpenAI / 中转等）---
# MODEL_USE=langchain_openai:ChatOpenAI
# MODEL_API_KEY=sk-your-key
# MODEL_BASE_URL=https://api.openai.com/v1
# MODEL_NAME=gpt-4o-mini
# MODEL_MAX_TOKENS=8192

# --- Anthropic Claude ---
# MODEL_USE=langchain_anthropic:ChatAnthropic
# MODEL_API_KEY=sk-ant-your-key
# MODEL_NAME=claude-sonnet-4-6
# MODEL_MAX_TOKENS=16384

# --- 小米 MiMo ---
# MODEL_USE=deerflow.models.patched_mimo:PatchedChatMiMo
# MODEL_API_KEY=sk-your-mimo-key
# MODEL_BASE_URL=https://api.xiaomimimo.com/v1
# MODEL_NAME=mimo-v2.5-pro
# MODEL_MAX_TOKENS=8192

# ============================================================
# Supabase
# ============================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# Tutor API
# ============================================================
# TUTOR_PORT=8765
# TUTOR_SESSION_BACKEND=memory
# TUTOR_SESSION_BACKEND=supabase
# DEER_FLOW_CONFIG_PATH=/app/config.yaml

# ============================================================
# LLM 模型配置
#
# MODEL_TYPE 可选值:
#   anthropic      → Claude (原生 Anthropic API)
#   openai         → OpenAI / OpenAI 兼容接口 (DeepSeek, 硅基流动, 百炼, Ollama 等)
#   openai-response → OpenAI Responses API (Codex)
#   mimo           → 小米 MiMo
#   vllm           → vLLM 本地推理服务
#
# 取消你要用的那组注释并填入真实 key 即可
# ============================================================

# --- Anthropic Claude ---
# MODEL_TYPE=anthropic
# MODEL_USE=deerflow.models.claude_provider:ClaudeChatModel
# MODEL_API_KEY=sk-ant-your-key
# MODEL_NAME=claude-sonnet-4-6
# MODEL_MAX_TOKENS=16384

# --- OpenAI (兼容接口) ---
# MODEL_TYPE=openai
# MODEL_USE=langchain_openai:ChatOpenAI
# MODEL_API_KEY=sk-your-key
# MODEL_BASE_URL=https://api.openai.com/v1
# MODEL_NAME=gpt-4o
# MODEL_MAX_TOKENS=8192

# --- OpenAI Responses API (Codex) ---
# MODEL_TYPE=openai-response
# MODEL_USE=deerflow.models.openai_codex_provider:CodexChatModel
# MODEL_API_KEY=sk-your-key
# MODEL_BASE_URL=https://api.openai.com/v1
# MODEL_NAME=gpt-4o
# MODEL_MAX_TOKENS=8192

# --- 小米 MiMo ---
# MODEL_TYPE=mimo
# MODEL_USE=deerflow.models.patched_mimo:PatchedChatMiMo
# MODEL_API_KEY=sk-your-mimo-key
# MODEL_BASE_URL=https://api.xiaomimimo.com/v1
# MODEL_NAME=mimo-v2.5-pro
# MODEL_MAX_TOKENS=8192

# --- vLLM 本地推理 ---
# MODEL_TYPE=vllm
# MODEL_USE=deerflow.models.vllm_provider:VLLMChatModel
# MODEL_API_KEY=not-needed
# MODEL_BASE_URL=http://localhost:8000/v1
# MODEL_NAME=Qwen/Qwen3-235B-A22B
# MODEL_MAX_TOKENS=8192

# ============================================================
# Supabase
# ============================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
